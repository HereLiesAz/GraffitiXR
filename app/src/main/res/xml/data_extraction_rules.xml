<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all data: user project .gxr files must not silently sync to Google Drive -->
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
